# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration
DATABASE_URL=postgresql://crawler:password@localhost:5432/crawler_db
POSTGRES_DB=crawler_db
POSTGRES_USER=crawler
POSTGRES_PASSWORD=password

# Scrapy Configuration
SCRAPY_SETTINGS_MODULE=crawler.settings
CONCURRENT_REQUESTS=16
CONCURRENT_REQUESTS_PER_DOMAIN=2
DOWNLOAD_DELAY=2
RANDOMIZE_DOWNLOAD_DELAY=1
AUTOTHROTTLE_ENABLED=True
AUTOTHROTTLE_START_DELAY=2
AUTOTHROTTLE_MAX_DELAY=10
AUTOTHROTTLE_TARGET_CONCURRENCY=2.0
AUTOTHROTTLE_DEBUG_STATS_CONSOL=False

# Crawler Configuration
CRAWLER_NAME=nigerian_news_crawler
CRAWLER_USER_AGENT=NigerianNewsResearchCrawler/1.0
CRAWLER_WORKERS=4
CRAWLER_LOG_LEVEL=INFO

# Monitoring Configuration
PROMETHEUS_PORT=9090
STATS_EXPORT_INTERVAL=60
ALERT_THRESHOLD_ITEMS_PER_MINUTE=100

# Storage Configuration
HTTPCACHE_ENABLED=True
HTTPCACHE_EXPIRATION_SECS=3600
HTTPCACHE_DIR=httpcache
SQLITE_DB_PATH=crawler_data.db

# Nigerian News Sites
BASE_DOMAINS=vanguardngr.com,punchng.com,thenationonlineng.net,thisdaylive.com,guardian.ng,sunnewsonline.com,leadership.ng,dailytrust.com
SEED_URLS=https://vanguardngr.com,https://punchng.com,https://thenationonlineng.net,https://www.thisdaylive.com,https://guardian.ng,https://sunnewsonline.com,https://leadership.ng,https://dailytrust.com

# Rate Limiting
REQUESTS_PER_MINUTE=120
BANDWIDTH_LIMIT=1000000

# Timeouts
DOWNLOAD_TIMEOUT=30
RESPONSE_TIMEOUT=30
CONNECT_TIMEOUT=10
