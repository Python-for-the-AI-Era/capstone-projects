# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/creditchek_models
MODEL_REGISTRY_DB_URL=postgresql://username:password@localhost:5432/model_registry

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql://username:password@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#model-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Model Configuration
MODEL_PATH=models/
DATA_PATH=data/
LOG_PATH=logs/

# Drift Detection Thresholds
PSI_THRESHOLD=0.2
DRIFT_DETECTION_FREQUENCY=daily
RETRAINING_TRIGGER_PSI=0.25

# Monitoring Configuration
MONITORING_DASHBOARD_PORT=8050
ALERT_EMAIL=admin@creditchek.com
